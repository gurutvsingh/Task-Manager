PORT=5000
# Leave MONGO_URI blank to use the local file-based JSON fallback database automatically.
# Set it to a valid MongoDB URI (local or Atlas) to use MongoDB database.
MONGO_URI=
JWT_SECRET=supersecretkeyfortaskmanager123!
# DB_TYPE can be 'mongodb' or 'json'. If left blank, it will automatically use 'mongodb' if MONGO_URI is set, otherwise 'json'.
DB_TYPE=json
